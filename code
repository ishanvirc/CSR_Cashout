function clearCells(sheet) {
  var clearRanges = [];
  var formatRanges = [];

  // PAYMENT TYPES INPUT
  Object.values(CONFIG.payments).forEach(({ message, amount, quantity, total }) => {

    // STOCK CART INPUT
    var stock_amount            = `${amount}${CONFIG.ranges.stock.amount_clear.start}:${amount}${CONFIG.ranges.stock.amount_clear.end}`;
    var stock_amount_overflow   = `${amount}${CONFIG.ranges.stock.overflow_clear.start}:${amount}${CONFIG.ranges.stock.overflow_clear.end}`;
    var stock_quantity          = `${quantity}${CONFIG.ranges.stock.quantity_clear.start}:${quantity}${CONFIG.ranges.stock.quantity_clear.end}`;
    var stock_quantity_overflow = `${quantity}${CONFIG.ranges.stock.overflow_clear.start}:${quantity}${CONFIG.ranges.stock.overflow_clear.end}`;

    // JOB CART INPUT
    var job_amount              = `${amount}${CONFIG.ranges.job.amount_clear.start}:${amount}${CONFIG.ranges.job.amount_clear.end}`;
    var job_amount_overflow     = `${amount}${CONFIG.ranges.job.overflow_clear.start}:${amount}${CONFIG.ranges.job.overflow_clear.end}`;
    var job_quantity            = `${quantity}${CONFIG.ranges.job.quantity_clear.start}:${quantity}${CONFIG.ranges.job.quantity_clear.end}`;
    var job_quantity_overflow   = `${quantity}${CONFIG.ranges.job.overflow_clear.start}:${quantity}${CONFIG.ranges.job.overflow_clear.end}`;

    // MESSAGE BOX
    var message_box = `${message}${CONFIG.message_row}`;
    
    // SPACESHIP SUM INPUT
    var spaceship_total     = `${total}${CONFIG.spaceship_row}`;
    var spaceship_quantity  = `${quantity}${CONFIG.spaceship_row}`;

    clearRanges.push(stock_amount);
    clearRanges.push(stock_amount_overflow);
    clearRanges.push(stock_quantity);
    clearRanges.push(stock_quantity_overflow);
    clearRanges.push(job_amount);
    clearRanges.push(job_amount_overflow);
    clearRanges.push(job_quantity);
    clearRanges.push(job_quantity_overflow);
    clearRanges.push(message_box);
    clearRanges.push(spaceship_total);
    clearRanges.push(spaceship_quantity);
    
    formatRanges.push(stock_amount);
    formatRanges.push(stock_amount_overflow);
    formatRanges.push(job_amount);
    formatRanges.push(job_amount_overflow);

  });

  // Clear calculator ranges
  Object.values(CONFIG.calculator).forEach(col => {
    clearRanges.push(`${col.quantity}${CONFIG.ranges.calculator.non_roll.start}:${col.quantity}${CONFIG.ranges.calculator.non_roll.end}`);
