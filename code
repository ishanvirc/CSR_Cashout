// ------------------------ HELP ------------------------------

function round2(x) {
  return Math.round(x * 100) / 100;
}


/**
 * Compute stock subtotal minus spaceship subtotal for each payment type.
 *
 * Returns:
 * {
 *   CASH:       { payment, stock, spaceship, diff },
 *   DEBIT:      { payment, stock, spaceship, diff },
 *   VISA:       { payment, stock, spaceship, diff },
 *   MASTERCARD: { payment, stock, spaceship, diff }
 * }
 */
function getStockDiffs(sheet) {
  var diffs = {};

  Object.entries(CONFIG.payments).forEach(([name, payment]) => {
    var totalCol = payment.total;

    var stockSubtotal = sheet.getRange(`${totalCol}${CONFIG.stock_subtotal_row}`).getValue();
    var spaceshipSubtotal = sheet.getRange(`${totalCol}${CONFIG.spaceship_row}`).getValue();

    diffs[name] = {
      payment:    payment,
      stock:      stockSubtotal,
      spaceship:  spaceshipSubtotal,
      diff:       stockSubtotal - spaceshipSubtotal
    };
  });

  return diffs;
}


/**
 * Build a list of STOCK rows (including overflow) for each payment type.
 *
 * Each entry looks like:
 * {
 *   typeName: "CASH" | "DEBIT" | "VISA" | "MASTERCARD",
 *   payment:  CONFIG.payments[typeName],
 *   row:      row index (number),
 *   amount:   value in AMOUNT column for that type/row,
 *   quantity: value in QUANTITY column for that type/row,
 *   total:    value in TOTAL column for that type/row
 * }
 *
 * We treat a row as "active" if quantity is non-empty and numeric.
 * (That corresponds to actual transactions, not just prefilled rates.)
 */
function buildStockRows(sheet) {
  var rows = [];
  var stockRange = CONFIG.ranges.stock;

  Object.entries(CONFIG.payments).forEach(([name, payment]) => {
    var amountCol   = payment.amount;
    var quantityCol = payment.quantity;
    var totalCol    = payment.total;

    // ---- Main stock block (e.g. rows 8–18) ----
    for (var r = stockRange.quantity_clear.start; r <= stockRange.quantity_clear.end; r++) {
      var amount   = sheet.getRange(`${amountCol}${r}`).getValue();
      var quantity = sheet.getRange(`${quantityCol}${r}`).getValue();
      var total    = sheet.getRange(`${totalCol}${r}`).getValue();

      // Only consider rows with a meaningful quantity (actual transactions)
      if (quantity !== "" && !isNaN(quantity) && quantity != 0) {
        rows.push({
          typeName: name,
          payment:  payment,
          row:      r,
          amount:   amount,
          quantity: quantity,
          total:    total
        });
      }
    }

    // ---- Stock overflow block (e.g. rows 59–72) ----
    for (var r = stockRange.overflow_clear.start; r <= stockRange.overflow_clear.end; r++) {
      var amountO   = sheet.getRange(`${amountCol}${r}`).getValue();
      var quantityO = sheet.getRange(`${quantityCol}${r}`).getValue();
      var totalO    = sheet.getRange(`${totalCol}${r}`).getValue();

      if (quantityO !== "" && !isNaN(quantityO) && quantityO != 0) {
        rows.push({
          typeName: name,
          payment:  payment,
          row:      r,
          amount:   amountO,
          quantity: quantityO,
          total:    totalO
        });
      }
    }
  });

  return rows;
}


/**
 * Build a list of UNIT transactions from the stock rows.
 *
 * Each row { amount, quantity } becomes `quantity` units of size `amount`.
 *
 * Each unit is:
 * {
 *   typeName: "CASH" | "DEBIT" | "VISA" | "MASTERCARD",
 *   payment:  CONFIG.payments[typeName],
 *   row:      row index in the sheet,
 *   amount:   numeric value of a *single* transaction,
 *   unitIndex: 1-based index of this unit within the row (for debugging)
 * }
 */
function buildStockUnits(stockRows) {
  var units = [];

  stockRows.forEach(function(r) {
    var qty = Number(r.quantity);
    var amt = Number(r.amount);

    // ignore weird/non-positive quantities
    if (!qty || isNaN(qty) || qty <= 0) return;
    if (isNaN(amt)) return;

    // conceptually: row represents qty separate transactions of value amt
    for (var k = 1; k <= qty; k++) {
      units.push({
        typeName:  r.typeName,
        payment:   r.payment,
        row:       r.row,
        amount:    amt,
        unitIndex: k
      });
    }
  });

  return units;
}



/**
 * Reconcile per-type diffs using unit transactions.
 *
 * diffs: {
 *   CASH: { payment, stock, spaceship, diff },
 *   ...
 * }
 * units: [
 *   { typeName, payment, row, amount, unitIndex },
 *   ...
 * ]
 *
 * Returns either:
 *   {
 *     unreleasedUnits: [unit, ...],
 *     misclassMoves:   [{ from, to, unit }, ...],
 *     residual:        { typeName: residualDiff }
 *   }
 * or null if no explanation exists.
 */
function reconcileUnits(diffs, units) {
  var typeNames = Object.keys(diffs);
  var epsilon = 0.0001;

  // Initial residual: stock - spaceship for each type
  var initialRes = {};
  typeNames.forEach(function(name) {
    initialRes[name] = Number(diffs[name].diff) || 0;
  });

  // Sort units by amount descending to prune faster
  units = units.slice().sort(function(a, b) {
    return (b.amount || 0) - (a.amount || 0);
  });

  function hasPositive(res) {
    return typeNames.some(function(t) { return res[t] > epsilon; });
  }

  function isAllZero(res) {
    return typeNames.every(function(t) { return Math.abs(res[t]) < epsilon; });
  }

  // Score for non-perfect solutions: how much unexplained spaceship-only we have
  function residualScore(res) {
    var s = 0;
    typeNames.forEach(function(t) {
      if (res[t] < -epsilon) {
        s += Math.abs(res[t]);
      }
    });
    return s;
  }

  function cloneRes(res) {
    var c = {};
    typeNames.forEach(function(t) { c[t] = res[t]; });
    return c;
  }

  var bestPerfect = null;         // residual ≈ 0
  var foundPerfect = false;
  var bestNonPerfect = null;      // residual <= 0, not all zero
  var bestNonPerfectScore = Infinity;

  function recordCandidate(res, unreleasedIdxs, misclassIdxs) {
    if (hasPositive(res)) return;   // not valid

    var snapshot = {
      unreleasedIdxs: unreleasedIdxs.slice(),
      misclassIdxs:   misclassIdxs.slice(),
      residual:       cloneRes(res)
    };

    if (isAllZero(res)) {
      // Perfect reconciliation
      if (!bestPerfect) {
        bestPerfect = snapshot;
      }
      foundPerfect = true;
    } else {
      // Non-perfect: all residuals <= 0, but some negative
      var score = residualScore(res);
      if (score < bestNonPerfectScore) {
        bestNonPerfectScore = score;
        bestNonPerfect = snapshot;
      }
    }
  }

  /**
   * DFS over units:
   *   idx            - current unit index
   *   res            - current residual map
   *   unreleasedIdxs - array of unit indices treated as UNRELEASED
   *   misclassIdxs   - array of { idx, from, to }
   */
  function dfs(idx, res, unreleasedIdxs, misclassIdxs) {
    // If we've already found a perfect solution, we can stop exploring.
    if (foundPerfect) return;

    // If no more units OR no positive residual left, treat as leaf candidate.
    if (idx >= units.length || !hasPositive(res)) {
      recordCandidate(res, unreleasedIdxs, misclassIdxs);
      return;
    }

    var u = units[idx];
    var t = u.typeName;
    var amt = Number(u.amount) || 0;

    if (amt <= 0) {
      // Skip weird zero/non-positive units
      dfs(idx + 1, res, unreleasedIdxs, misclassIdxs);
      return;
    }

    // --- OPTION 1: unit is OK (no error) ---
    dfs(idx + 1, res, unreleasedIdxs, misclassIdxs);
    if (foundPerfect) return;

    // --- OPTION 2: UNRELEASED (have receipt, not released) ---
    // Only require that this type currently has some positive mismatch.
    // It's okay if we "overshoot" and make it negative; leftover negative
    // will be treated as spaceship-only later (for non-perfect solutions).
    if (res[t] > epsilon) {
      var res2 = cloneRes(res);
      res2[t] -= amt;
      unreleasedIdxs.push(idx);
      dfs(idx + 1, res2, unreleasedIdxs, misclassIdxs);
      unreleasedIdxs.pop();
      if (foundPerfect) return;
    }

    // --- OPTION 3: MISCLASSIFIED to some other type 'to' ---
    for (var i = 0; i < typeNames.length; i++) {
      if (foundPerfect) return;

      var to = typeNames[i];
      if (to === t) continue;

      // Heuristic: only move from a type that currently has
      // positive residual to one that has negative residual.
      if (res[t] <= epsilon) continue;
      if (res[to] >= -epsilon) continue;

      var res3 = cloneRes(res);
      res3[t]  -= amt;
      res3[to] += amt;

      // No extra sign checks: we allow overshoot here; it will be
      // filtered by the final hasPositive()/isAllZero logic.
      misclassIdxs.push({ idx: idx, from: t, to: to });
      dfs(idx + 1, res3, unreleasedIdxs, misclassIdxs);
      misclassIdxs.pop();
    }
  }

  // Start DFS
  dfs(0, initialRes, [], []);

  var chosen = null;
  if (bestPerfect) {
    chosen = bestPerfect;              // prefer exact reconciliation
  } else if (bestNonPerfect) {
    chosen = bestNonPerfect;           // fallback: minimal spaceship-only residual
  } else {
    return null;                       // no explanation found
  }

  // Convert index-based solution to actual unit objects
  var unreleasedUnits = chosen.unreleasedIdxs.map(function(i) {
    return units[i];
  });

  var misclassMoves = chosen.misclassIdxs.map(function(m) {
    return {
      from: m.from,
      to:   m.to,
      unit: units[m.idx]
    };
  });

  return {
    unreleasedUnits: unreleasedUnits,
    misclassMoves:   misclassMoves,
    residual:        chosen.residual
  };
}



/**
 * Aggregate unreleased, misclassified, and missing-receipt info per payment type.
 *
 * Returns:
 * {
 *   CASH: {
 *     payment: CONFIG.payments.CASH,
 *     unreleased: { totalAmount, count, rows: { [row]: true } },
 *     misclassFrom: {
 *       VISA: { totalAmount, count, rows: { [row]: true } },
 *       ...
 *     },
 *     missingReceipts: { totalAmount }
 *   },
 *   ...
 * }
 */
function buildPerTypeIssues(diffs, solution) {
  var perType = {};

  // Initialize base structure for each payment type
  Object.entries(CONFIG.payments).forEach(function([name, payment]) {
    perType[name] = {
      payment: payment,
      unreleased: {
        totalAmount: 0,
        count: 0,
        rows: {}     // map row -> true
      },
      misclassFrom: {}, // toType -> { totalAmount, count, rows }
      missingReceipts: {
        totalAmount: 0
      }
    };
  });

  // Unreleased units
  solution.unreleasedUnits.forEach(function(unit) {
    var t = unit.typeName;
    if (!perType[t]) return;

    var issues = perType[t].unreleased;
    issues.count += 1;
    issues.totalAmount += Number(unit.amount) || 0;
    issues.rows[unit.row] = true;
  });

  // Misclassified units (from -> to)
  solution.misclassMoves.forEach(function(move) {
    var from = move.from;
    var to   = move.to;
    var unit = move.unit;

    if (!perType[from]) return;

    var misFrom = perType[from].misclassFrom;
    if (!misFrom[to]) {
      misFrom[to] = {
        totalAmount: 0,
        count: 0,
        rows: {}
      };
    }
    misFrom[to].count += 1;
    misFrom[to].totalAmount += Number(unit.amount) || 0;
    misFrom[to].rows[unit.row] = true;
  });

  // Missing receipts / spaceship-only (from residual < 0)
  Object.keys(perType).forEach(function(name) {
    var res = solution.residual && solution.residual[name];
    if (typeof res === 'number' && res < -0.0001) {
      perType[name].missingReceipts.totalAmount = -res;
    }
  });

  return perType;
}

function colorUnreleased(sheet, perTypeIssues) {
  Object.entries(perTypeIssues).forEach(function([typeName, issues]) {
    var payment = issues.payment;
    var amountCol = payment.amount;
    var totalCol  = payment.total;

    var rowsMap = issues.unreleased.rows;
    Object.keys(rowsMap).forEach(function(rowStr) {
      var r = parseInt(rowStr, 10);
      if (!r) return;
      sheet.getRange(amountCol + r).setBackground(CONFIG.HELP_COLORS.UNRELEASED);
    });
  });
}


function colorMisclassified(sheet, perTypeIssues) {
  Object.entries(perTypeIssues).forEach(function([fromType, issues]) {
    var payment = issues.payment;
    var amountCol = payment.amount;

    var misFrom = issues.misclassFrom;
    Object.entries(misFrom).forEach(function([toType, info]) {
      var color = CONFIG.HELP_COLORS[toType]; // color of wrong type
      if (!color) return;

      Object.keys(info.rows).forEach(function(rowStr) {
        var r = parseInt(rowStr, 10);
        if (!r) return;
        sheet.getRange(amountCol + r).setBackground(color);
      });
    });
  });
}

function buildPaymentMessage(typeName, issues) {
  var parts = [];

  // 1) Unreleased
  if (issues.unreleased.count > 0) {
    var amtUnr = round2(issues.unreleased.totalAmount);
    parts.push(
      issues.unreleased.count + " unreleased " + typeName +
      " txns ≈ $" + amtUnr + ". Release highlighted rows."
    );
  }

  // 2) Misclassified FROM this type
  var mis = issues.misclassFrom;
  var misKeys = Object.keys(mis);
  misKeys.forEach(function(toType) {
    var info = mis[toType];
    var amt = round2(info.totalAmount);
    parts.push(
      "Some " + typeName + " txns ≈ $" + amt +
      " released as " + toType + ". Fix type on spaceship."
    );
  });

  // 3) Missing receipts / spaceship-only
  if (issues.missingReceipts.totalAmount > 0.005) {
    var missAmt = round2(issues.missingReceipts.totalAmount);
    parts.push(
      "Spaceship has extra $" + missAmt + " " + typeName +
      ". Check for missing receipts / wrong date."
    );
  }

  // No issues -> balanced
  if (parts.length === 0) {
    return "Payment type balanced, no reconciliation needed.";
  }

  if (parts.length > 3) {
    parts = parts.slice(0, 2);
    parts.push("More issues detected. Review highlighted rows.");
  }

  return parts.join("\n");
}


function writePaymentMessages(sheet, perTypeIssues) {
  Object.entries(perTypeIssues).forEach(function([typeName, issues]) {
    var msg = buildPaymentMessage(typeName, issues);
    var messageCol = issues.payment.message; // e.g. 'B', 'F', 'J', 'N'
    var messageRow = CONFIG.message_row;     // 27
    sheet.getRange(messageCol + messageRow).setValue(msg);
  });
}


function applyReconciliation(sheet, diffs, solution) {
  var perTypeIssues = buildPerTypeIssues(diffs, solution);

  // Color cells
  colorUnreleased(sheet, perTypeIssues);
  colorMisclassified(sheet, perTypeIssues);

  // Write message text into each payment type's message box
  writePaymentMessages(sheet, perTypeIssues);
}


function balance() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  sheet.expandAllRowGroups();

  // --- PHASE 1: Read and compute diffs ---
  var diffs = getStockDiffs(sheet);

  // --- PHASE 1.5: Spaceship subtotal input requirements ---------
  // 1) Require at lease one spaceship subtotal cell to be non-blank
  var spaceshipValues  = Object.values(diffs).map(function(d) {return d.spaceship; });

  var hasSpaceshipInput = spaceshipValues.some(function(v) {
    // Treat any non-empty, non-null value as "input" (0 is allowed).
    return v !== "" && v !== null && v !== undefined;
  });

  if (!hasSpaceshipInput) {
    // No spaceship subtotals at all -> ask user to input at lease one, don't proceed.
    Object.entries(CONFIG.payments).forEach(function([name, payment]) {
      var message_box = payment.message + CONFIG.message_row;
      sheet.getRange(message_box).setValue(
        "Enter at least one SPACESHIP TOTAL to begin diagnostic."
      );
    });
    return false;
  }

  // 2) For any payment type where spaceship subtotal is blank, treat it as equal to stop subtotal (so diff becomes 0).
  Object.values(diffs).forEach(function(d) {
    if (d.spaceship === "" || d.spaceship === null || d.spaceship === undefined) {
      d.spaceship = d.stock;
      d.diff = d.stock - d.spaceship; // = 0
    }
  });

  // Check if all types match exactly.
  var allGood = Object.values(diffs).every(d => Math.abs(d.diff) < 0.0000001);

  if (allGood) {
    Object.entries(CONFIG.payments).forEach(([name, payment]) => {
      sheet.getRange(`${payment.message}${CONFIG.message_row}`)
      .setValue("All payment types balanced.");
    });
    return true;
  }

  // --- PHASE 2: Build STOCK row objects ---
  var stockRows = buildStockRows(sheet);

  // --- PHASE 3: Build UNIT representation (LIST of) of stock transactions ---
  var units = buildStockUnits(stockRows);

  // If there are mismatches but no units to reason about. 
  if (units.length === 0) {
    Object.entries(CONFIG.payments).forEach(function([name, payment]) {
      var messageCell = payment.message + CONFIG.message_row;
      sheet.getRange(messageCell).setValue(
        "Mismatch detected; no stock transactions found to analyze. Check values."
      );
    });
    return false;
  }

  // --- PHASE 4: Run DFS Diagnostic ------
  var solution = null;
  if (!allGood && units.length > 0) {
    solution = reconcileUnits(diffs, units);
  }
  
  if (!solution) {
    // Helper couldn't find a consistent explanation
    Object.entries(CONFIG.payments).forEach(function([name, payment]) {
      var messageCell = payment.message + CONFIG.message_row;
      sheet.getRange(messageCell).setValue(
        "Mismatch detected; helper could not reconcile. Check amounts and payment types."
      );
    });
    return false;
  }

  // --- PHASE 5: Apply visualization and messages.
  applyReconciliation(sheet, diffs, solution);

  return true;
  
}


function findSubsetSum(nums, target) {
  let result = [];
  function backtrack(start, sum, subset, rows) {
    if (sum == target) {
      result = rows.slice(); // store row indices
      return true;
    }
    if (sum > target) return false;

    for (let i = start; i < nums.length; i++) {
      if (backtrack(i+1, sum + nums[i], subset.concat(nums[i]), rows.concat(i))) return true;
    }
    return false;
  }
  backtrack(0, 0, [], []);
  return result;
}






