  // Job Quantity Range
  setQuantityColumnFormula(sheet, CONFIG.ranges.job.amount_clear.start, CONFIG.ranges.job.amount_clear.end);
  // Job Quantity Range (overflow) 
  setQuantityColumnFormula(sheet, CONFIG.ranges.job.overflow_clear.start, CONFIG.ranges.job.overflow_clear.end);
  

  // Reset SUM formulas -------------------------
  Object.values(CONFIG.payments).forEach(payment => {
    // Define Total Ranges
    var stock_total = `${payment.total}${CONFIG.ranges.stock.quantity_clear.start}:${payment.total}${CONFIG.ranges.stock.quantity_clear.end}, ${payment.total}${CONFIG.ranges.stock.overflow_clear.start}:${payment.total}${CONFIG.ranges.stock.overflow_clear.end}`;
