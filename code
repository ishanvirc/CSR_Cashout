  });

  clearRanges.forEach(r => sheet.getRange(r).clearContent());
  formatRanges.forEach(r => sheet.getRange(r).setBackground('white'));
}


function resetValues(sheet) {  
  CONFIG.static_values.common_rates.forEach(entry => {
    Object.values(CONFIG.payments).forEach(({ amount }) => {
      sheet.getRange(`${amount}${entry.row}`).setValue(entry.value);
      sheet.getRange(`${amount}${entry.row}`).setBackground('#EFEFEF');
    });
  });

  Object.values(CONFIG.calculator).forEach(calc => {
    CONFIG.static_values.currency.forEach(entry => {
      sheet.getRange(`${calc.amount}${entry.row}`).setValue(entry.value);
    });
  });

  setHeaders(sheet);
  setHelpDescriptions(sheet);
}

function setHeaders(sheet) {
  Object.entries(CONFIG.header_map).forEach(([label, cells]) => {
    cells.forEach(cell => {
      sheet.getRange(cell).setValue(label);
    });
  });
}

function buildRichText(text, rules) {
  const builder = SpreadsheetApp.newRichTextValue().setText(text);

  Object.entries(rules).forEach(([word, color]) => {
    let start = text.indexOf(word);
    while (start !== -1) {
      const end = start + word.length;
      builder.setTextStyle(
        start,
        end,
        SpreadsheetApp.newTextStyle().setForegroundColor(color).build()
      );
      start = text.indexOf(word, end); // next occurrence
    }
  });

  return builder.build();
}

function setHelpDescriptions(sheet) {
  const lightGreen1 = "#90EE90"; // payments
  const lightCyan1  = "#76a5af"; // category words

  const specialText =
    "\"SPECIAL PAYMENTS\" includes payments received for RETAIL SERVICES, PARTIAL PAYMENTS, PASSES, and UNRELEASED vehicles.";
  const stockText =
    "\"STOCK CART PAYMENTS\" includes payments received for RELEASED vehicles.";

  // Pull the cell addresses from CONFIG.header_map
  const specialCellRef = CONFIG.header_map[specialText][0]; // 'B31'
  const stockCellRef   = CONFIG.header_map[stockText][0];   // 'N31'

  // SPECIAL PAYMENTS line (B31)
  sheet.getRange(specialCellRef).setRichTextValue(
    buildRichText(specialText, {
      "payments":         lightGreen1, // lowercase only
      "RETAIL SERVICES":  lightCyan1,
      "PARTIAL PAYMENTS": lightCyan1,
      "PASSES":           lightCyan1,
      "UNRELEASED":       lightCyan1
    })
  );

  // STOCK CART PAYMENTS line (N31)
  sheet.getRange(stockCellRef).setRichTextValue(
    buildRichText(stockText, {
      "payments": lightGreen1,
      "RELEASED": lightCyan1
    })
  );
}


function setTotalColumnFormula(sheet, start, end) {
  for (let row = start; row <= end; row++) {
    Object.values(CONFIG.payments).forEach(({ total, amount, quantity}) => {
      const formula = `IF(ISBLANK(${quantity}${row}), ${amount}${row}, ${amount}${row}*${quantity}${row})`;
      sheet.getRange(`${total}${row}`).setFormula(formula);
    });
  }
}

function setQuantityColumnFormula(sheet,start, end) {
  for (let row = start; row <= end; row++) {
    Object.values(CONFIG.payments).forEach(({ quantity, amount}) => {
      const formula = `IF(ISBLANK(${amount}${row}),,1)`;
      sheet.getRange(`${quantity}${row}`).setFormula(formula);
    });
  }
}

function resetFormulas(sheet) {
  // Reset COMMON RATES formulas ------------------
  Object.values(CONFIG.payments).forEach(payment => {
    for (let row = CONFIG.static_values.common_rates[0].row; row <= CONFIG.static_values.common_rates[CONFIG.static_values.common_rates.length -1].row; row++){
      const formula = `=${payment.amount}${row}*${payment.quantity}${row}`;
      sheet.getRange(`${payment.total}${row}`).setFormula(formula);
    }
  });
    
  // Reset TOTAL column formulas -----------------
  // Stock Total Range
  setTotalColumnFormula(sheet, CONFIG.ranges.stock.amount_clear.start, CONFIG.ranges.stock.amount_clear.end);
  // Stock Total Range (overflow)
  setTotalColumnFormula(sheet, CONFIG.ranges.stock.overflow_clear.start, CONFIG.ranges.stock.overflow_clear.end);
  // Job Total Range
  setTotalColumnFormula(sheet, CONFIG.ranges.job.amount_clear.start, CONFIG.ranges.job.amount_clear.end);
  // Job Total Range (overflow)
  setTotalColumnFormula(sheet, CONFIG.ranges.job.overflow_clear.start, CONFIG.ranges.job.overflow_clear.end);
  
  // Reset QUANTITY column formulas ------------------
  // Stock Quantity Range 
  setQuantityColumnFormula(sheet, CONFIG.ranges.stock.amount_clear.start, CONFIG.ranges.stock.amount_clear.end);
  // Stock Quantity Range (overflow)
  setQuantityColumnFormula(sheet, CONFIG.ranges.stock.overflow_clear.start, CONFIG.ranges.stock.overflow_clear.end);
  // Job Quantity Range
  setQuantityColumnFormula(sheet, CONFIG.ranges.job.amount_clear.start, CONFIG.ranges.job.amount_clear.end);
  // Job Quantity Range (overflow) 
  setQuantityColumnFormula(sheet, CONFIG.ranges.job.overflow_clear.start, CONFIG.ranges.job.overflow_clear.end);
  

  // Reset SUM formulas -------------------------
  Object.values(CONFIG.payments).forEach(payment => {
    // Define Total Ranges
    var stock_total = `${payment.total}${CONFIG.ranges.stock.quantity_clear.start}:${payment.total}${CONFIG.ranges.stock.quantity_clear.end}, ${payment.total}${CONFIG.ranges.stock.overflow_clear.start}:${payment.total}${CONFIG.ranges.stock.overflow_clear.end}`;
    var job_total = `${payment.total}${CONFIG.ranges.job.quantity_clear.start}:${payment.total}${CONFIG.ranges.job.quantity_clear.end}, ${payment.total}${CONFIG.ranges.job.overflow_clear.start}:${payment.total}${CONFIG.ranges.job.overflow_clear.end}`;

    // Define Quantity Ranges
    var stock_quantity = `${payment.quantity}${CONFIG.ranges.stock.quantity_clear.start}:${payment.quantity}${CONFIG.ranges.stock.quantity_clear.end}, ${payment.quantity}${CONFIG.ranges.stock.overflow_clear.start}:${payment.quantity}${CONFIG.ranges.stock.overflow_clear.end}`;
    var job_quantity = `${payment.quantity}${CONFIG.ranges.job.quantity_clear.start}:${payment.quantity}${CONFIG.ranges.job.quantity_clear.end}, ${payment.quantity}${CONFIG.ranges.job.overflow_clear.start}:${payment.quantity}${CONFIG.ranges.job.overflow_clear.end}`;

    // TOTAL sum formula
    var payment_total_formula     = `=SUM(${stock_total}, ${job_total})`;
    var stock_subtotal_formula    = `=SUM(${stock_total})`;
    var job_subtotal_formula      = `=SUM(${job_total})`;

    // Quantity Sum formula
    var payment_quantity_formula  = `=SUM(${stock_quantity}, ${job_quantity})`;
    var stock_quantity_formula    = `=SUM(${stock_quantity})`;
    var job_quantity_formula      = `=SUM(${job_quantity})`;

    // Set TOTAL
    sheet.getRange(`${payment.total}${CONFIG.sum_row}`).setFormula(payment_total_formula);
    sheet.getRange(`${payment.quantity}${CONFIG.sum_row}`).setFormula(payment_quantity_formula);
    // Set Stock SUBTOTAL
    sheet.getRange(`${payment.total}${CONFIG.stock_subtotal_row}`).setFormula(stock_subtotal_formula);
    sheet.getRange(`${payment.quantity}${CONFIG.stock_subtotal_row}`).setFormula(stock_quantity_formula);
    // Set Job SUBTOTAL
    sheet.getRange(`${payment.total}${CONFIG.job_subtotal_row}`).setFormula(job_subtotal_formula);
    sheet.getRange(`${payment.quantity}${CONFIG.job_subtotal_row}`).setFormula(job_quantity_formula);

    // Set Differences
    // diff formulas
    var global_diff    = `=${payment.total}${CONFIG.sum_row}-${payment.total}${CONFIG.spaceship_row}`;
    var stock_diff     = `=${payment.total}${CONFIG.stock_subtotal_row}-${payment.total}${CONFIG.spaceship_row}`;
    sheet.getRange(`${payment.total}${CONFIG.diff_row}`).setFormula(global_diff);
    sheet.getRange(`${payment.total}${CONFIG.diff_stock_row}`).setFormula(stock_diff);    

    CONFIG.global_total_formula += `+${payment.total}${CONFIG.sum_row}`;
    CONFIG.global_quantity_formula += `+${payment.quantity}${CONFIG.sum_row}`;
    CONFIG.global_spaceship_formula += `+${payment.total}${CONFIG.spaceship_row}`;
  });

  // Calculator ---------------------------
  Object.values(CONFIG.calculator).forEach(calc => {
    // Rolls
    for (let row = CONFIG.ranges.calculator.roll.start; row <= CONFIG.ranges.calculator.roll.end; row++) {
      const formula = `=${calc.amount}${row}*${calc.quantity}${row}`;
      sheet.getRange(`${calc.total}${row}`).setFormula(formula);
    }
    // Coins
    for (let row = CONFIG.ranges.calculator.coin.start; row <= CONFIG.ranges.calculator.coin.end; row++) {
      const formula = `=${calc.amount}${row}*${calc.quantity}${row}`;
      sheet.getRange(`${calc.total}${row}`).setFormula(formula);
    }
    // CASH
    for (let row = CONFIG.ranges.calculator.cash.start; row <= CONFIG.ranges.calculator.cash.end; row++) {
      const offset = row - CONFIG.ranges.calculator.cash.start;
      let val;
      
      if(calc.id == 1) {
        val = CONFIG.cash_values[offset];
        const formula = `=${val}*${calc.quantity}${row}`;
        sheet.getRange(`${calc.total}${row}`).setFormula(formula);
      }
      if (calc.id == 2) {
        val = CONFIG.cash_values[CONFIG.cash_values.length - 1 - offset];
        const formula = `=${val}*${calc.quantity}${row}`;
        sheet.getRange(`${calc.total}${row}`).setFormula(formula);
      }
    }
  });

  // CALCULATOR (Cash Removal)
  // TOTAL:
  sheet.getRange(`${CONFIG.calculator.cash_removal.total}${CONFIG.calculator.cash_removal.total_row}`).setFormula(`=SUM(${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.non_roll.start}:${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.non_roll.end}, ${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.roll.start}:${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.roll.end})`);
  // REMOVAL AMOUNT:
  sheet.getRange(`${CONFIG.calculator.cash_removal.total}${CONFIG.calculator.cash_removal.removal_row}`).setFormula(`=${CONFIG.payments.CASH.total}${CONFIG.sum_row}-${CONFIG.calculator.cash_removal.total}${CONFIG.calculator.cash_removal.total_row}`);
  // SIDEBAR:
  // CASH TOTAL
  sheet.getRange(`${CONFIG.calculator.cash_removal.sidebar.column}${CONFIG.calculator.cash_removal.sidebar.cash_total_row}`).setFormula(`=SUM(${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.cash.start}:${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.cash.end})`);
  // COIN TOTAL
  sheet.getRange(`${CONFIG.calculator.cash_removal.sidebar.column}${CONFIG.calculator.cash_removal.sidebar.coin_total_row}`).setFormula(`=SUM(${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.coin.start}:${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.coin.end},${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.roll.start}:${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.roll.end})`);
  // ROLLS
  sheet.getRange(`${CONFIG.calculator.cash_removal.sidebar.column}${CONFIG.calculator.cash_removal.sidebar.rolls_row}`).setFormula(`=SUM(${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.roll.start}:${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.roll.end})`);
  // SPARE CHANGE
  sheet.getRange(`${CONFIG.calculator.cash_removal.sidebar.column}${CONFIG.calculator.cash_removal.sidebar.spare_change_row}`).setFormula(`=SUM(${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.coin.start}:${CONFIG.calculator.cash_removal.total}${CONFIG.ranges.calculator.coin.end})`);

  
  // CALCULATOR (Till Count)
  // TOTAL:
  sheet.getRange(`${CONFIG.calculator.till_count.total}${CONFIG.calculator.till_count.total_row}`).setFormula(`=SUM(${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.non_roll.start}:${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.non_roll.end}, ${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.roll.start}:${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.roll.end})`);
  // DISTANCE:
  sheet.getRange(`${CONFIG.calculator.till_count.total}${CONFIG.calculator.till_count.distance_row}`).setFormula(`=IF(COUNTA(${CONFIG.calculator.till_count.quantity}${CONFIG.ranges.calculator.non_roll.start}:${CONFIG.calculator.till_count.quantity}${CONFIG.ranges.calculator.non_roll.end}, ${CONFIG.calculator.till_count.quantity}${CONFIG.ranges.calculator.roll.start}:${CONFIG.calculator.till_count.quantity}${CONFIG.ranges.calculator.roll.end}), ${CONFIG.calculator.till_count.total}${CONFIG.calculator.till_count.total_row}-350, "☺")`);
  // SIDEBAR:
  // CASH TOTAL
  sheet.getRange(`${CONFIG.calculator.till_count.sidebar.column}${CONFIG.calculator.till_count.sidebar.cash_total_row}`).setFormula(`=SUM(${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.cash.start}:${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.cash.end})`);
  // COIN TOTAL
  sheet.getRange(`${CONFIG.calculator.till_count.sidebar.column}${CONFIG.calculator.till_count.sidebar.coin_total_row}`).setFormula(`=SUM(${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.coin.start}:${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.coin.end},${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.roll.start}:${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.roll.end})`);
  // ROLLS
  sheet.getRange(`${CONFIG.calculator.till_count.sidebar.column}${CONFIG.calculator.till_count.sidebar.rolls_row}`).setFormula(`=SUM(${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.roll.start}:${CONFIG.calculator.till_count.total}${CONFIG.ranges.calculator.roll.end})`);
  // SPARE CHANGE
